---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="即梦AI Watermark Remover / 即梦AI水印移除">
  <div class="tool-page">
    <h1>即梦AI Watermark Remover</h1>
    <p class="subtitle">Remove 即梦AI's visible watermark from AI-generated images / 移除即梦AI生成图片的可见水印</p>
    <p class="seo-note">Experimental tool based on reverse alpha blending technique. Works best on images with white watermarks in the bottom-right corner.</p>

    <div class="tool-container">
      <div class="drop-zone" id="drop-zone">
        <input type="file" id="file-input" accept="image/*" hidden>
        <p>Drop image here or <button id="browse-btn">browse</button></p>
        <p class="hint">Supports PNG, JPG, WebP</p>
      </div>

      <div id="status" class="status hidden"></div>

      <div id="preview-section" class="preview-section hidden">
        <div class="preview-grid">
          <div class="preview-card">
            <h3>Original</h3>
            <div class="preview-wrap" id="original-wrap">
              <canvas id="original-canvas"></canvas>
            </div>
          </div>
          <div class="preview-card">
            <h3>Cleaned <span class="fullscreen-hint">(click to fullscreen)</span></h3>
            <div class="preview-wrap clickable" id="cleaned-wrap">
              <canvas id="cleaned-canvas"></canvas>
            </div>
          </div>
        </div>
        <div class="file-info">
          <span id="file-name"></span>
          <span id="file-size"></span>
          <span id="img-dimensions"></span>
        </div>
        <div class="format-selector">
          <h4>Download Format:</h4>
          <div class="format-options">
            <button class="format-btn" data-format="png">
              <div class="format-info">
                <strong>PNG</strong>
                <span class="format-size" id="size-png">--</span>
              </div>
              <svg class="download-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
            </button>
            <button class="format-btn" data-format="jpeg">
              <div class="format-info">
                <strong>JPEG</strong>
                <span class="format-size" id="size-jpeg">--</span>
              </div>
              <svg class="download-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
            </button>
            <button class="format-btn" data-format="webp">
              <div class="format-info">
                <strong>WebP</strong>
                <span class="format-size" id="size-webp">--</span>
              </div>
              <svg class="download-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                <polyline points="7 10 12 15 17 10"></polyline>
                <line x1="12" y1="15" x2="12" y2="3"></line>
              </svg>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div id="lightbox" class="lightbox hidden">
    <button id="lightbox-close" class="lightbox-close">&times;</button>
    <canvas id="lightbox-canvas"></canvas>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/pica@9.0.1/dist/pica.min.js"></script>
</Layout>

<style>
.tool-page {
  max-width: 1100px;
  margin: 0 auto;
  padding: 2rem 0;
}

.subtitle {
  color: var(--text-secondary);
  margin-bottom: 0.5rem;
}

.seo-note {
  font-size: 0.85rem;
  color: var(--text-secondary);
  margin-bottom: 1.5rem;
}

.tool-container {
  background: var(--bg-secondary);
  padding: 2rem;
  border-radius: 12px;
  border: 1px solid var(--border);
}

.drop-zone {
  border: 2px dashed var(--border);
  border-radius: 12px;
  padding: 3rem 2rem;
  text-align: center;
  transition: border-color 0.2s, background 0.2s;
}

.drop-zone.dragover {
  border-color: var(--primary);
  background: rgba(var(--primary-rgb), 0.05);
}

.drop-zone p {
  margin: 0.5rem 0;
  color: var(--text);
}

.drop-zone .hint {
  font-size: 0.85rem;
  color: var(--text-secondary);
}

#browse-btn {
  background: none;
  border: none;
  color: var(--primary);
  cursor: pointer;
  text-decoration: underline;
  font-size: inherit;
}

.status {
  margin-top: 1rem;
  padding: 0.75rem 1rem;
  border-radius: 8px;
  font-size: 0.9rem;
  text-align: center;
}

.status.processing {
  background: rgba(var(--primary-rgb), 0.1);
  color: var(--primary);
}

.status.success {
  background: rgba(34, 197, 94, 0.1);
  color: #16a34a;
}

.status.error {
  background: rgba(239, 68, 68, 0.1);
  color: #dc2626;
}

.preview-section {
  margin-top: 1.5rem;
}

.preview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

.preview-card h3 {
  font-size: 0.9rem;
  color: var(--text-secondary);
  margin-bottom: 0.5rem;
  text-align: center;
}

.preview-wrap {
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
  background: var(--bg);
}

.preview-wrap canvas {
  width: 100%;
  height: auto;
  display: block;
}

.file-info {
  margin-top: 0.75rem;
  font-size: 0.85rem;
  color: var(--text-secondary);
  display: flex;
  justify-content: center;
  gap: 1rem;
  flex-wrap: wrap;
}

.format-selector {
  margin-top: 1rem;
  padding: 1rem;
  background: var(--bg);
  border-radius: 8px;
  border: 1px solid var(--border);
}

.format-selector h4 {
  font-size: 0.9rem;
  color: var(--text);
  margin: 0 0 0.75rem 0;
  font-weight: 600;
}

.format-options {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
}

.format-btn {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
  padding: 0.75rem 1rem;
  border: 1px solid var(--border);
  border-radius: 8px;
  cursor: pointer;
  transition: all 0.2s;
  background: var(--bg-secondary);
  font-size: 1rem;
}

.format-btn:hover {
  border-color: var(--primary);
  background: rgba(var(--primary-rgb), 0.05);
}

.format-btn:hover .download-icon {
  color: var(--primary);
}

.format-info {
  display: flex;
  align-items: baseline;
  gap: 0.5rem;
}

.format-btn strong {
  color: var(--text);
  font-size: 0.95rem;
  font-weight: 600;
}

.format-size {
  color: var(--text-secondary);
  font-size: 0.85rem;
}

.download-icon {
  color: var(--text-secondary);
  transition: color 0.2s;
  flex-shrink: 0;
}

@media (max-width: 640px) {
  .format-options {
    grid-template-columns: 1fr;
  }
}

.preview-wrap.clickable {
  cursor: pointer;
  position: relative;
}

.preview-wrap.clickable:hover {
  border-color: var(--primary);
}

.fullscreen-hint {
  font-size: 0.75rem;
  font-weight: 400;
  color: var(--text-secondary);
}

.lightbox {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
}

.lightbox canvas {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  border-radius: 4px;
}

.lightbox-close {
  position: absolute;
  top: 1rem;
  right: 1.5rem;
  background: none;
  border: none;
  color: #fff;
  font-size: 2.5rem;
  cursor: pointer;
  line-height: 1;
  z-index: 10000;
  opacity: 0.7;
  transition: opacity 0.2s;
}

.lightbox-close:hover {
  opacity: 1;
}

.hidden {
  display: none !important;
}

@media (max-width: 480px) {
  .preview-grid {
    grid-template-columns: 1fr;
  }
}
</style>

<script>
// Watermark removal constants
// Watermark configuration for 即梦AI
// The watermark is 551x182 pixels in the bottom right corner
const WATERMARK_CONFIG = {
  logoWidth: 551,
  logoHeight: 182,
};

const BRIGHTNESS_THRESHOLD = 180;

function detectWatermarkPosition(w: number, h: number) {
  return {
    x: w - WATERMARK_CONFIG.logoWidth,
    y: h - WATERMARK_CONFIG.logoHeight,
    width: WATERMARK_CONFIG.logoWidth,
    height: WATERMARK_CONFIG.logoHeight,
  };
}

function detectWatermarkMask(imageData: ImageData, x: number, y: number, width: number, height: number): Uint8Array {
  const mask = new Uint8Array(width * height);

  for (let row = 0; row < height; row++) {
    for (let col = 0; col < width; col++) {
      const imgIdx = ((y + row) * imageData.width + (x + col)) * 4;

      // Calculate brightness as average of RGB
      const r = imageData.data[imgIdx];
      const g = imageData.data[imgIdx + 1];
      const b = imageData.data[imgIdx + 2];
      const brightness = (r + g + b) / 3;

      // Mark as watermark if brightness is above threshold
      mask[row * width + col] = brightness > BRIGHTNESS_THRESHOLD ? 1 : 0;
    }
  }

  return mask;
}

function removeWatermark(imageData: ImageData, mask: Uint8Array, position: { x: number; y: number; width: number; height: number }) {
  const { x, y, width, height } = position;
  const data = imageData.data;

  for (let row = 0; row < height; row++) {
    for (let col = 0; col < width; col++) {
      const maskIdx = row * width + col;

      if (mask[maskIdx] === 1) {
        // This is a watermark pixel, replace with nearby darker pixels
        const imgIdx = ((y + row) * imageData.width + (x + col)) * 4;

        // Get a larger 15x15 window around this pixel
        const rowMin = Math.max(0, row - 7);
        const rowMax = Math.min(height, row + 8);
        const colMin = Math.max(0, col - 7);
        const colMax = Math.min(width, col + 8);

        const rValues: number[] = [];
        const gValues: number[] = [];
        const bValues: number[] = [];

        // Collect non-watermark pixels in the window
        for (let wy = rowMin; wy < rowMax; wy++) {
          for (let wx = colMin; wx < colMax; wx++) {
            const wMaskIdx = wy * width + wx;
            if (mask[wMaskIdx] === 0) {
              const wImgIdx = ((y + wy) * imageData.width + (x + wx)) * 4;
              rValues.push(data[wImgIdx]);
              gValues.push(data[wImgIdx + 1]);
              bValues.push(data[wImgIdx + 2]);
            }
          }
        }

        // Replace with median of nearby non-watermark pixels
        if (rValues.length > 0) {
          rValues.sort((a, b) => a - b);
          gValues.sort((a, b) => a - b);
          bValues.sort((a, b) => a - b);

          const mid = Math.floor(rValues.length / 2);
          data[imgIdx] = rValues[mid];
          data[imgIdx + 1] = gValues[mid];
          data[imgIdx + 2] = bValues[mid];
        }
      }
    }
  }
}

  for (let row = 0; row < height; row++) {
    for (let col = 0; col < width; col++) {
      const imgIdx = ((y + row) * imageData.width + (x + col)) * 4;
      const alphaIdx = row * width + col;
      let alpha = alphaMap[alphaIdx];

      if (alpha < ALPHA_THRESHOLD) continue;

      alpha = Math.min(alpha, MAX_ALPHA);
      const oneMinusAlpha = 1.0 - alpha;

      for (let c = 0; c < 3; c++) {
        const watermarked = imageData.data[imgIdx + c];
        const original = (watermarked - alpha * LOGO_VALUE) / oneMinusAlpha;
        imageData.data[imgIdx + c] = Math.max(0, Math.min(255, Math.round(original)));
      }
    }
  }
}

// UI Elements
const dropZone = document.getElementById('drop-zone')!;
const fileInput = document.getElementById('file-input') as HTMLInputElement;
const browseBtn = document.getElementById('browse-btn')!;
const status = document.getElementById('status')!;
const previewSection = document.getElementById('preview-section')!;
const originalCanvas = document.getElementById('original-canvas') as HTMLCanvasElement;
const cleanedCanvas = document.getElementById('cleaned-canvas') as HTMLCanvasElement;
const fileNameEl = document.getElementById('file-name')!;
const fileSizeEl = document.getElementById('file-size')!;
const imgDimensionsEl = document.getElementById('img-dimensions')!;
const sizePngEl = document.getElementById('size-png')!;
const sizeJpegEl = document.getElementById('size-jpeg')!;
const sizeWebpEl = document.getElementById('size-webp')!;
const formatButtons = document.querySelectorAll<HTMLButtonElement>('.format-btn');

let cleanedBlobs: { png: Blob; jpeg: Blob; webp: Blob } | null = null;
let currentFileName = 'cleaned';

function formatSize(bytes: number): string {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
  return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
}

function showStatus(msg: string, type: 'processing' | 'success' | 'error') {
  status.textContent = msg;
  status.className = `status ${type}`;
  status.classList.remove('hidden');
}

async function generateFormats(sourceCanvas: HTMLCanvasElement): Promise<{ png: Blob; jpeg: Blob; webp: Blob }> {
  const pica = (window as any).pica();
  const formats: any = {};

  // PNG - Lossless
  formats.png = await new Promise<Blob>((resolve) => {
    sourceCanvas.toBlob((blob) => resolve(blob!), 'image/png');
  });

  // JPEG - Use pica for quality
  const jpegCanvas = document.createElement('canvas');
  jpegCanvas.width = sourceCanvas.width;
  jpegCanvas.height = sourceCanvas.height;
  await pica.resize(sourceCanvas, jpegCanvas, { quality: 3 });
  formats.jpeg = await new Promise<Blob>((resolve) => {
    jpegCanvas.toBlob((blob) => resolve(blob!), 'image/jpeg', 0.92);
  });

  // WebP - Use pica for quality
  const webpCanvas = document.createElement('canvas');
  webpCanvas.width = sourceCanvas.width;
  webpCanvas.height = sourceCanvas.height;
  await pica.resize(sourceCanvas, webpCanvas, { quality: 3, alpha: true });
  formats.webp = await new Promise<Blob>((resolve) => {
    webpCanvas.toBlob((blob) => resolve(blob!), 'image/webp', 0.92);
  });

  return formats;
}

async function processImage(file: File) {
  showStatus('Processing...', 'processing');
  previewSection.classList.add('hidden');

  const img = new Image();
  const url = URL.createObjectURL(file);

  try {
    await new Promise<void>((resolve, reject) => {
      img.onload = () => resolve();
      img.onerror = () => reject(new Error('Failed to load image'));
      img.src = url;
    });

    const w = img.naturalWidth;
    const h = img.naturalHeight;

    // Draw original
    originalCanvas.width = w;
    originalCanvas.height = h;
    const origCtx = originalCanvas.getContext('2d')!;
    origCtx.drawImage(img, 0, 0);

    // Process
    cleanedCanvas.width = w;
    cleanedCanvas.height = h;
    const cleanCtx = cleanedCanvas.getContext('2d')!;
    cleanCtx.drawImage(img, 0, 0);

    const imageData = cleanCtx.getImageData(0, 0, w, h);
    const position = detectWatermarkPosition(w, h);
    const mask = detectWatermarkMask(imageData, position.x, position.y, position.width, position.height);

    removeWatermark(imageData, mask, position);
    cleanCtx.putImageData(imageData, 0, 0);

    // Generate all format versions
    cleanedBlobs = await generateFormats(cleanedCanvas);

    const baseName = file.name.substring(0, file.name.lastIndexOf('.')) || file.name;
    currentFileName = baseName;

    fileNameEl.textContent = file.name;
    fileSizeEl.textContent = formatSize(file.size);
    imgDimensionsEl.textContent = `${w} × ${h}`;

    // Update format sizes
    sizePngEl.textContent = formatSize(cleanedBlobs.png.size);
    sizeJpegEl.textContent = formatSize(cleanedBlobs.jpeg.size);
    sizeWebpEl.textContent = formatSize(cleanedBlobs.webp.size);

    previewSection.classList.remove('hidden');
    showStatus(`Watermark removed (${position.width}×${position.height} region processed)`, 'success');

    // Scroll to preview section
    setTimeout(() => {
      previewSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 100);
  } catch (err: any) {
    showStatus(`Error: ${err.message}`, 'error');
  } finally {
    URL.revokeObjectURL(url);
  }
}

// Event listeners
browseBtn.addEventListener('click', () => fileInput.click());

// Format button click handlers
formatButtons.forEach(button => {
  button.addEventListener('click', () => {
    if (!cleanedBlobs) return;

    const format = button.dataset.format as 'png' | 'jpeg' | 'webp';
    const blob = cleanedBlobs[format];
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${currentFileName}-cleaned.${format}`;
    a.click();
    URL.revokeObjectURL(url);
  });
});

dropZone.addEventListener('dragover', (e) => {
  e.preventDefault();
  dropZone.classList.add('dragover');
});

dropZone.addEventListener('dragleave', () => {
  dropZone.classList.remove('dragover');
});

dropZone.addEventListener('drop', (e) => {
  e.preventDefault();
  dropZone.classList.remove('dragover');
  const file = e.dataTransfer?.files[0];
  if (file && file.type.startsWith('image/')) {
    processImage(file);
  }
});

fileInput.addEventListener('change', () => {
  const file = fileInput.files?.[0];
  if (file) processImage(file);
});

// Lightbox for fullscreen cleaned image
const lightbox = document.getElementById('lightbox')!;
const lightboxCanvas = document.getElementById('lightbox-canvas') as HTMLCanvasElement;
const lightboxClose = document.getElementById('lightbox-close')!;
const cleanedWrap = document.getElementById('cleaned-wrap')!;

cleanedWrap.addEventListener('click', () => {
  if (!cleanedCanvas.width) return;
  lightboxCanvas.width = cleanedCanvas.width;
  lightboxCanvas.height = cleanedCanvas.height;
  const ctx = lightboxCanvas.getContext('2d')!;
  ctx.drawImage(cleanedCanvas, 0, 0);
  lightbox.classList.remove('hidden');
  document.body.style.overflow = 'hidden';
});

function closeLightbox() {
  lightbox.classList.add('hidden');
  document.body.style.overflow = '';
}

lightboxClose.addEventListener('click', closeLightbox);
lightbox.addEventListener('click', (e) => {
  if (e.target === lightbox) closeLightbox();
});
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && !lightbox.classList.contains('hidden')) closeLightbox();
});
</script>
