}

.metadata-title {
  font-weight: 600;
  margin-bottom: 0.5rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.metadata-title.detected {
  color: #f59e0b;
}

.metadata-title.clean {
  color: #10b981;
}

.metadata-list {
  margin: 0.5rem 0 0 0;
  padding-left: 1.5rem;
  color: var(--text-secondary);
}

.metadata-list li {
  margin: 0.25rem 0;
}

.metadata-info {
  margin-top: 1rem;
  padding: 0.75rem 1rem;
  background: rgba(245, 158, 11, 0.1);
  border-radius: 8px;
  border: 1px solid rgba(245, 158, 11, 0.3);
  font-size: 0.85rem;
  color: #f59e0b;
  text-align: center;
}

.actions {
  margin-top: 1rem;
}

.format-selector {
  margin-top: 1rem;
  padding: 1rem;
  background: var(--bg);
  border-radius: 8px;
  border: 1px solid var(--border);
}

.format-selector h4 {
  font-size: 0.9rem;
  color: var(--text);
  margin: 0 0 0.75rem 0;
  font-weight: 600;
}

.format-options {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
}

.format-btn {
