---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Gemini Watermark Remover / Gemini水印移除">
  <div class="tool-page">
    <h1>Gemini Watermark Remover</h1>
    <p class="subtitle">Remove Gemini's visible watermark from AI-generated images / 移除Gemini AI生成图片的可见水印</p>
    <p class="seo-note">Based on the <a href="https://github.com/ZhiGroup/nano-banana" target="_blank" rel="noopener">Nano Banana</a> algorithm for Gemini watermark removal.</p>

    <div class="tool-container">
      <div class="drop-zone" id="drop-zone">
        <input type="file" id="file-input" accept="image/*" hidden>
        <p>Drop image here or <button id="browse-btn">browse</button></p>
        <p class="hint">Supports PNG, JPG, WebP</p>
      </div>

      <div id="status" class="status hidden"></div>

      <div id="preview-section" class="preview-section hidden">
        <div class="preview-grid">
          <div class="preview-card">
            <h3>Original</h3>
            <div class="preview-wrap" id="original-wrap">
              <canvas id="original-canvas"></canvas>
            </div>
          </div>
          <div class="preview-card">
            <h3>Cleaned <span class="fullscreen-hint">(click to fullscreen)</span></h3>
            <div class="preview-wrap clickable" id="cleaned-wrap">
              <canvas id="cleaned-canvas"></canvas>
            </div>
          </div>
        </div>
        <div class="file-info">
          <span id="file-name"></span>
          <span id="file-size"></span>
          <span id="img-dimensions"></span>
        </div>
        <div class="actions">
          <button id="download-btn" class="primary-btn">Download Cleaned Image</button>
        </div>
      </div>
    </div>
  </div>

  <div id="lightbox" class="lightbox hidden">
    <button id="lightbox-close" class="lightbox-close">&times;</button>
    <canvas id="lightbox-canvas"></canvas>
  </div>
</Layout>

<style>
.tool-page {
  max-width: 1100px;
  margin: 0 auto;
  padding: 2rem 0;
}

.subtitle {
  color: var(--text-secondary);
  margin-bottom: 0.5rem;
}

.seo-note {
  font-size: 0.85rem;
  color: var(--text-secondary);
  margin-bottom: 1.5rem;
}

.seo-note a {
  color: var(--primary);
  text-decoration: underline;
}

.tool-container {
  background: var(--bg-secondary);
  padding: 2rem;
  border-radius: 12px;
  border: 1px solid var(--border);
}

.drop-zone {
  border: 2px dashed var(--border);
  border-radius: 12px;
  padding: 3rem 2rem;
  text-align: center;
  transition: border-color 0.2s, background 0.2s;
}

.drop-zone.dragover {
  border-color: var(--primary);
  background: rgba(var(--primary-rgb), 0.05);
}

.drop-zone p {
  margin: 0.5rem 0;
  color: var(--text);
}

.drop-zone .hint {
  font-size: 0.85rem;
  color: var(--text-secondary);
}

#browse-btn {
  background: none;
  border: none;
  color: var(--primary);
  cursor: pointer;
  text-decoration: underline;
  font-size: inherit;
}

.status {
  margin-top: 1rem;
  padding: 0.75rem 1rem;
  border-radius: 8px;
  font-size: 0.9rem;
  text-align: center;
}

.status.processing {
  background: rgba(var(--primary-rgb), 0.1);
  color: var(--primary);
}

.status.success {
  background: rgba(34, 197, 94, 0.1);
  color: #16a34a;
}

.status.error {
  background: rgba(239, 68, 68, 0.1);
  color: #dc2626;
}

.preview-section {
  margin-top: 1.5rem;
}

.preview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

.preview-card h3 {
  font-size: 0.9rem;
  color: var(--text-secondary);
  margin-bottom: 0.5rem;
  text-align: center;
}

.preview-wrap {
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
  background: var(--bg);
}

.preview-wrap canvas {
  width: 100%;
  height: auto;
  display: block;
}

.file-info {
  margin-top: 0.75rem;
  font-size: 0.85rem;
  color: var(--text-secondary);
  display: flex;
  justify-content: center;
  gap: 1rem;
  flex-wrap: wrap;
}

.actions {
  margin-top: 1rem;
}

.primary-btn {
  width: 100%;
  padding: 1rem;
  font-size: 1rem;
  font-weight: 600;
  background: var(--primary);
  color: white;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  transition: opacity 0.2s;
}

.primary-btn:hover {
  opacity: 0.9;
}

.preview-wrap.clickable {
  cursor: pointer;
  position: relative;
}

.preview-wrap.clickable:hover {
  border-color: var(--primary);
}

.fullscreen-hint {
  font-size: 0.75rem;
  font-weight: 400;
  color: var(--text-secondary);
}

.lightbox {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
}

.lightbox canvas {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  border-radius: 4px;
}

.lightbox-close {
  position: absolute;
  top: 1rem;
  right: 1.5rem;
  background: none;
  border: none;
  color: #fff;
  font-size: 2.5rem;
  cursor: pointer;
  line-height: 1;
  z-index: 10000;
  opacity: 0.7;
  transition: opacity 0.2s;
}

.lightbox-close:hover {
  opacity: 1;
}

.hidden {
  display: none !important;
}

@media (max-width: 480px) {
  .preview-grid {
    grid-template-columns: 1fr;
  }
}
</style>

<script>
// Constants matching the source algorithm
const ALPHA_THRESHOLD = 0.002;
const MAX_ALPHA = 0.99;
const LOGO_VALUE = 255;

// Alpha map cache
const alphaMaps: Record<number, Float32Array> = {};

async function loadAlphaMap(size: number): Promise<Float32Array> {
  if (alphaMaps[size]) return alphaMaps[size];

  const img = new Image();
  await new Promise<void>((resolve, reject) => {
    img.onload = () => resolve();
    img.onerror = () => reject(new Error(`Failed to load bg_${size}.png`));
    img.src = `/assets/bg_${size}.png`;
  });

  const canvas = document.createElement('canvas');
  canvas.width = size;
  canvas.height = size;
  const ctx = canvas.getContext('2d')!;
  ctx.drawImage(img, 0, 0);
  const { data } = ctx.getImageData(0, 0, size, size);

  const alphaMap = new Float32Array(size * size);
  for (let i = 0; i < alphaMap.length; i++) {
    const idx = i * 4;
    alphaMap[i] = Math.max(data[idx], data[idx + 1], data[idx + 2]) / 255.0;
  }

  alphaMaps[size] = alphaMap;
  return alphaMap;
}

function detectConfig(w: number, h: number) {
  if (w > 1024 && h > 1024) {
    return { logoSize: 96, marginRight: 64, marginBottom: 64 };
  }
  return { logoSize: 48, marginRight: 32, marginBottom: 32 };
}

function calcPosition(w: number, h: number, config: ReturnType<typeof detectConfig>) {
  return {
    x: w - config.marginRight - config.logoSize,
    y: h - config.marginBottom - config.logoSize,
    width: config.logoSize,
    height: config.logoSize,
  };
}

function removeWatermark(imageData: ImageData, alphaMap: Float32Array, position: { x: number; y: number; width: number; height: number }) {
  const { x, y, width, height } = position;

  for (let row = 0; row < height; row++) {
    for (let col = 0; col < width; col++) {
      const imgIdx = ((y + row) * imageData.width + (x + col)) * 4;
      const alphaIdx = row * width + col;
      let alpha = alphaMap[alphaIdx];

      if (alpha < ALPHA_THRESHOLD) continue;

      alpha = Math.min(alpha, MAX_ALPHA);
      const oneMinusAlpha = 1.0 - alpha;

      for (let c = 0; c < 3; c++) {
        const watermarked = imageData.data[imgIdx + c];
        const original = (watermarked - alpha * LOGO_VALUE) / oneMinusAlpha;
        imageData.data[imgIdx + c] = Math.max(0, Math.min(255, Math.round(original)));
      }
    }
  }
}

// UI Elements
const dropZone = document.getElementById('drop-zone')!;
const fileInput = document.getElementById('file-input') as HTMLInputElement;
const browseBtn = document.getElementById('browse-btn')!;
const status = document.getElementById('status')!;
const previewSection = document.getElementById('preview-section')!;
const originalCanvas = document.getElementById('original-canvas') as HTMLCanvasElement;
const cleanedCanvas = document.getElementById('cleaned-canvas') as HTMLCanvasElement;
const fileNameEl = document.getElementById('file-name')!;
const fileSizeEl = document.getElementById('file-size')!;
const imgDimensionsEl = document.getElementById('img-dimensions')!;
const downloadBtn = document.getElementById('download-btn')!;

let cleanedBlob: Blob | null = null;
let currentFileName = 'cleaned.png';

function formatSize(bytes: number): string {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
  return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
}

function showStatus(msg: string, type: 'processing' | 'success' | 'error') {
  status.textContent = msg;
  status.className = `status ${type}`;
  status.classList.remove('hidden');
}

async function processImage(file: File) {
  showStatus('Processing...', 'processing');
  previewSection.classList.add('hidden');

  const img = new Image();
  const url = URL.createObjectURL(file);

  try {
    await new Promise<void>((resolve, reject) => {
      img.onload = () => resolve();
      img.onerror = () => reject(new Error('Failed to load image'));
      img.src = url;
    });

    const w = img.naturalWidth;
    const h = img.naturalHeight;

    // Draw original
    originalCanvas.width = w;
    originalCanvas.height = h;
    const origCtx = originalCanvas.getContext('2d')!;
    origCtx.drawImage(img, 0, 0);

    // Process
    cleanedCanvas.width = w;
    cleanedCanvas.height = h;
    const cleanCtx = cleanedCanvas.getContext('2d')!;
    cleanCtx.drawImage(img, 0, 0);

    const imageData = cleanCtx.getImageData(0, 0, w, h);
    const config = detectConfig(w, h);
    const position = calcPosition(w, h, config);
    const alphaMap = await loadAlphaMap(config.logoSize);

    removeWatermark(imageData, alphaMap, position);
    cleanCtx.putImageData(imageData, 0, 0);

    // Prepare download blob
    cleanedBlob = await new Promise<Blob>((resolve) => {
      cleanedCanvas.toBlob((blob) => resolve(blob!), 'image/png');
    });

    const ext = file.name.lastIndexOf('.') >= 0 ? file.name.substring(file.name.lastIndexOf('.')) : '.png';
    const baseName = file.name.substring(0, file.name.lastIndexOf('.')) || file.name;
    currentFileName = `${baseName}-cleaned${ext}`;

    fileNameEl.textContent = file.name;
    fileSizeEl.textContent = formatSize(file.size);
    imgDimensionsEl.textContent = `${w} × ${h}`;

    previewSection.classList.remove('hidden');
    showStatus(`Watermark removed (${config.logoSize}×${config.logoSize} logo detected)`, 'success');
  } catch (err: any) {
    showStatus(`Error: ${err.message}`, 'error');
  } finally {
    URL.revokeObjectURL(url);
  }
}

// Event listeners
browseBtn.addEventListener('click', () => fileInput.click());

dropZone.addEventListener('dragover', (e) => {
  e.preventDefault();
  dropZone.classList.add('dragover');
});

dropZone.addEventListener('dragleave', () => {
  dropZone.classList.remove('dragover');
});

dropZone.addEventListener('drop', (e) => {
  e.preventDefault();
  dropZone.classList.remove('dragover');
  const file = e.dataTransfer?.files[0];
  if (file && file.type.startsWith('image/')) {
    processImage(file);
  }
});

fileInput.addEventListener('change', () => {
  const file = fileInput.files?.[0];
  if (file) processImage(file);
});

downloadBtn.addEventListener('click', () => {
  if (!cleanedBlob) return;
  const url = URL.createObjectURL(cleanedBlob);
  const a = document.createElement('a');
  a.href = url;
  a.download = currentFileName;
  a.click();
  URL.revokeObjectURL(url);
});

// Lightbox for fullscreen cleaned image
const lightbox = document.getElementById('lightbox')!;
const lightboxCanvas = document.getElementById('lightbox-canvas') as HTMLCanvasElement;
const lightboxClose = document.getElementById('lightbox-close')!;
const cleanedWrap = document.getElementById('cleaned-wrap')!;

cleanedWrap.addEventListener('click', () => {
  if (!cleanedCanvas.width) return;
  lightboxCanvas.width = cleanedCanvas.width;
  lightboxCanvas.height = cleanedCanvas.height;
  const ctx = lightboxCanvas.getContext('2d')!;
  ctx.drawImage(cleanedCanvas, 0, 0);
  lightbox.classList.remove('hidden');
  document.body.style.overflow = 'hidden';
});

function closeLightbox() {
  lightbox.classList.add('hidden');
  document.body.style.overflow = '';
}

lightboxClose.addEventListener('click', closeLightbox);
lightbox.addEventListener('click', (e) => {
  if (e.target === lightbox) closeLightbox();
});
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && !lightbox.classList.contains('hidden')) closeLightbox();
});
</script>
