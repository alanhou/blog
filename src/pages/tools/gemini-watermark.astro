  margin: 0 auto;
  padding: 2rem 0;
}

.subtitle {
  color: var(--text-secondary);
  margin-bottom: 0.5rem;
}

.seo-note {
  font-size: 0.85rem;
  color: var(--text-secondary);
  margin-bottom: 1.5rem;
}

.seo-note a {
  color: var(--primary);
  text-decoration: underline;
}

.tool-container {
  background: var(--bg-secondary);
  padding: 2rem;
  border-radius: 12px;
  border: 1px solid var(--border);
}

.drop-zone {
  border: 2px dashed var(--border);
  border-radius: 12px;
  padding: 3rem 2rem;
  text-align: center;
  transition: border-color 0.2s, background 0.2s;
}

.drop-zone.dragover {
  border-color: var(--primary);
  background: rgba(var(--primary-rgb), 0.05);
}

.drop-zone p {
  margin: 0.5rem 0;
  color: var(--text);
}

.drop-zone .hint {
  font-size: 0.85rem;
  color: var(--text-secondary);
}

#browse-btn {
  background: none;
  border: none;
  color: var(--primary);
  cursor: pointer;
  text-decoration: underline;
  font-size: inherit;
}

.status {
  margin-top: 1rem;
  padding: 0.75rem 1rem;
  border-radius: 8px;
  font-size: 0.9rem;
  text-align: center;
}

.status.processing {
  background: rgba(var(--primary-rgb), 0.1);
  color: var(--primary);
}

.status.success {
  background: rgba(34, 197, 94, 0.1);
  color: #16a34a;
}

.status.error {
  background: rgba(239, 68, 68, 0.1);
  color: #dc2626;
}

.preview-section {
  margin-top: 1.5rem;
}

.preview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

.preview-card h3 {
  font-size: 0.9rem;
  color: var(--text-secondary);
  margin-bottom: 0.5rem;
