  .format-options {
    grid-template-columns: 1fr;
  }
}

.primary-btn {
  width: 100%;
  padding: 1rem;
  font-size: 1rem;
  font-weight: 600;
  background: var(--primary);
  color: white;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  transition: opacity 0.2s;
}

.primary-btn:hover {
  opacity: 0.9;
}

.preview-wrap.clickable {
  cursor: pointer;
  position: relative;
}

.preview-wrap.clickable:hover {
  border-color: var(--primary);
}

.fullscreen-hint {
  font-size: 0.75rem;
  font-weight: 400;
  color: var(--text-secondary);
}

.lightbox {
  position: fixed;
  inset: 0;
  z-index: 9999;
  background: rgba(0, 0, 0, 0.92);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem;
}

.lightbox canvas {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  border-radius: 4px;
}

.lightbox-close {
  position: absolute;
  top: 1rem;
  right: 1.5rem;
  background: none;
  border: none;
  color: #fff;
  font-size: 2.5rem;
  cursor: pointer;
  line-height: 1;
  z-index: 10000;
  opacity: 0.7;
  transition: opacity 0.2s;
}

.lightbox-close:hover {
  opacity: 1;
}

.hidden {
  display: none !important;
}

@media (max-width: 480px) {
  .preview-grid {
    grid-template-columns: 1fr;
  }
}
</style>

<script>
// Constants matching the source algorithm
const ALPHA_THRESHOLD = 0.002;
const MAX_ALPHA = 0.99;
const LOGO_VALUE = 255;

// Alpha map cache
const alphaMaps: Record<number, Float32Array> = {};

async function loadAlphaMap(size: number): Promise<Float32Array> {
  if (alphaMaps[size]) return alphaMaps[size];

  const img = new Image();
  await new Promise<void>((resolve, reject) => {
    img.onload = () => resolve();
    img.onerror = () => reject(new Error(`Failed to load bg_${size}.png`));
    img.src = `/assets/bg_${size}.png`;
  });

  const canvas = document.createElement('canvas');
  canvas.width = size;
  canvas.height = size;
  const ctx = canvas.getContext('2d')!;
  ctx.drawImage(img, 0, 0);
  const { data } = ctx.getImageData(0, 0, size, size);

  const alphaMap = new Float32Array(size * size);
  for (let i = 0; i < alphaMap.length; i++) {
    const idx = i * 4;
    alphaMap[i] = Math.max(data[idx], data[idx + 1], data[idx + 2]) / 255.0;
  }

  alphaMaps[size] = alphaMap;
  return alphaMap;
}

function detectConfig(w: number, h: number) {
  if (w > 1024 && h > 1024) {
    return { logoSize: 96, marginRight: 64, marginBottom: 64 };
  }
  return { logoSize: 48, marginRight: 32, marginBottom: 32 };
}

function calcPosition(w: number, h: number, config: ReturnType<typeof detectConfig>) {
  return {
    x: w - config.marginRight - config.logoSize,
    y: h - config.marginBottom - config.logoSize,
    width: config.logoSize,
    height: config.logoSize,
  };
}

function removeWatermark(imageData: ImageData, alphaMap: Float32Array, position: { x: number; y: number; width: number; height: number }) {
  const { x, y, width, height } = position;

  for (let row = 0; row < height; row++) {
    for (let col = 0; col < width; col++) {
      const imgIdx = ((y + row) * imageData.width + (x + col)) * 4;
      const alphaIdx = row * width + col;
      let alpha = alphaMap[alphaIdx];

      if (alpha < ALPHA_THRESHOLD) continue;

      alpha = Math.min(alpha, MAX_ALPHA);
      const oneMinusAlpha = 1.0 - alpha;

      for (let c = 0; c < 3; c++) {
        const watermarked = imageData.data[imgIdx + c];
        const original = (watermarked - alpha * LOGO_VALUE) / oneMinusAlpha;
        imageData.data[imgIdx + c] = Math.max(0, Math.min(255, Math.round(original)));
      }
    }
  }
}

// UI Elements
const dropZone = document.getElementById('drop-zone')!;
const fileInput = document.getElementById('file-input') as HTMLInputElement;
const browseBtn = document.getElementById('browse-btn')!;
const status = document.getElementById('status')!;
const previewSection = document.getElementById('preview-section')!;
const originalCanvas = document.getElementById('original-canvas') as HTMLCanvasElement;
const cleanedCanvas = document.getElementById('cleaned-canvas') as HTMLCanvasElement;
const fileNameEl = document.getElementById('file-name')!;
const fileSizeEl = document.getElementById('file-size')!;
const imgDimensionsEl = document.getElementById('img-dimensions')!;
const downloadBtn = document.getElementById('download-btn')!;
const sizePngEl = document.getElementById('size-png')!;
const sizeJpegEl = document.getElementById('size-jpeg')!;
const sizeWebpEl = document.getElementById('size-webp')!;
const formatButtons = document.querySelectorAll<HTMLButtonElement>('.format-btn');
const metadataInfoEl = document.getElementById('metadata-info')!;
const metadataStatusEl = document.getElementById('metadata-status')!;

let cleanedBlobs: { png: Blob; jpeg: Blob; webp: Blob } | null = null;
let currentFileName = 'cleaned';
let selectedFormat: 'png' | 'jpeg' | 'webp' = 'jpeg';

function formatSize(bytes: number): string {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
  return (bytes / (1024 * 1024)).toFixed(2) + ' MB';
}

async function detectMetadata(file: File): Promise<string[]> {
  const buffer = await file.arrayBuffer();
  const bytes = new Uint8Array(buffer);
  const detected: string[] = [];

  // Convert bytes to string for text-based markers
  const text = new TextDecoder('utf-8', { fatal: false }).decode(bytes.slice(0, Math.min(bytes.length, 100000)));

  // Check for C2PA markers
  if (text.includes('c2pa') || text.includes('jumbf')) {
    detected.push('C2PA');
  }

  // Check for EXIF
  if (text.includes('Exif\0\0')) {
    detected.push('EXIF');
  }

  // Check for XMP
  if (text.includes('<x:xmpmeta') || text.includes('<rdf:RDF')) {
    detected.push('XMP');
  }

  // Check for IPTC
  if (text.includes('Photoshop 3.0')) {
    detected.push('IPTC');
  }

  return detected;
}

function showStatus(msg: string, type: 'processing' | 'success' | 'error') {
  status.textContent = msg;
  status.className = `status ${type}`;
  status.classList.remove('hidden');
}

async function generateFormats(sourceCanvas: HTMLCanvasElement): Promise<{ png: Blob; jpeg: Blob; webp: Blob }> {
  const pica = (window as any).pica();
  const formats: any = {};

  // PNG - Lossless (direct from canvas)
  formats.png = await new Promise<Blob>((resolve) => {
    sourceCanvas.toBlob((blob) => resolve(blob!), 'image/png');
  });

  // JPEG - Use pica for quality
  const jpegCanvas = document.createElement('canvas');
  jpegCanvas.width = sourceCanvas.width;
  jpegCanvas.height = sourceCanvas.height;
  await pica.resize(sourceCanvas, jpegCanvas, { quality: 3 });
  formats.jpeg = await new Promise<Blob>((resolve) => {
    jpegCanvas.toBlob((blob) => resolve(blob!), 'image/jpeg', 0.92);
  });

  // WebP - Use pica for quality
  const webpCanvas = document.createElement('canvas');
  webpCanvas.width = sourceCanvas.width;
  webpCanvas.height = sourceCanvas.height;
  await pica.resize(sourceCanvas, webpCanvas, { quality: 3, alpha: true });
  formats.webp = await new Promise<Blob>((resolve) => {
    webpCanvas.toBlob((blob) => resolve(blob!), 'image/webp', 0.92);
  });

  return formats;
}

async function processImage(file: File) {
  showStatus('Processing...', 'processing');
  previewSection.classList.add('hidden');

  const img = new Image();
  const url = URL.createObjectURL(file);

  try {
    await new Promise<void>((resolve, reject) => {
      img.onload = () => resolve();
      img.onerror = () => reject(new Error('Failed to load image'));
      img.src = url;
    });

    const w = img.naturalWidth;
    const h = img.naturalHeight;

    // Draw original
    originalCanvas.width = w;
    originalCanvas.height = h;
    const origCtx = originalCanvas.getContext('2d')!;
    origCtx.drawImage(img, 0, 0);

    // Process
    cleanedCanvas.width = w;
    cleanedCanvas.height = h;
    const cleanCtx = cleanedCanvas.getContext('2d')!;
    cleanCtx.drawImage(img, 0, 0);

    const imageData = cleanCtx.getImageData(0, 0, w, h);
    const config = detectConfig(w, h);
    const position = calcPosition(w, h, config);
    const alphaMap = await loadAlphaMap(config.logoSize);

    removeWatermark(imageData, alphaMap, position);
    cleanCtx.putImageData(imageData, 0, 0);

    // Generate all format versions
    cleanedBlobs = await generateFormats(cleanedCanvas);

    const baseName = file.name.substring(0, file.name.lastIndexOf('.')) || file.name;
    currentFileName = baseName;

    fileNameEl.textContent = file.name;
    fileSizeEl.textContent = formatSize(file.size);
    imgDimensionsEl.textContent = `${w} × ${h}`;

    // Detect metadata
    const metadata = await detectMetadata(file);
    if (metadata.length > 0) {
      metadataStatusEl.textContent = `⚠️ Detected metadata: ${metadata.join(', ')} (will be removed in output)`;
      metadataInfoEl.classList.remove('hidden');
    } else {
      metadataInfoEl.classList.add('hidden');
    }

    // Update format sizes
    sizePngEl.textContent = formatSize(cleanedBlobs.png.size);
    sizeJpegEl.textContent = formatSize(cleanedBlobs.jpeg.size);
    sizeWebpEl.textContent = formatSize(cleanedBlobs.webp.size);

    previewSection.classList.remove('hidden');
    showStatus(`Watermark removed (${config.logoSize}×${config.logoSize} logo detected)`, 'success');

    // Scroll to preview section
    setTimeout(() => {
      previewSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }, 100);
  } catch (err: any) {
    showStatus(`Error: ${err.message}`, 'error');
  } finally {
    URL.revokeObjectURL(url);
  }
}

// Event listeners
browseBtn.addEventListener('click', () => fileInput.click());

// Format button click handlers - direct download
formatButtons.forEach(button => {
  button.addEventListener('click', () => {
    if (!cleanedBlobs) return;

    const format = button.dataset.format as 'png' | 'jpeg' | 'webp';
    const blob = cleanedBlobs[format];
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `${currentFileName}-cleaned.${format}`;
    a.click();
    URL.revokeObjectURL(url);
  });
});

dropZone.addEventListener('dragover', (e) => {
  e.preventDefault();
  dropZone.classList.add('dragover');
});

dropZone.addEventListener('dragleave', () => {
  dropZone.classList.remove('dragover');
});

dropZone.addEventListener('drop', (e) => {
  e.preventDefault();
  dropZone.classList.remove('dragover');
  const file = e.dataTransfer?.files[0];
  if (file && file.type.startsWith('image/')) {
    processImage(file);
  }
});

fileInput.addEventListener('change', () => {
  const file = fileInput.files?.[0];
  if (file) processImage(file);
});

// Removed separate download button - format buttons now handle downloads directly

// Lightbox for fullscreen cleaned image
const lightbox = document.getElementById('lightbox')!;
const lightboxCanvas = document.getElementById('lightbox-canvas') as HTMLCanvasElement;
const lightboxClose = document.getElementById('lightbox-close')!;
const cleanedWrap = document.getElementById('cleaned-wrap')!;

cleanedWrap.addEventListener('click', () => {
  if (!cleanedCanvas.width) return;
  lightboxCanvas.width = cleanedCanvas.width;
  lightboxCanvas.height = cleanedCanvas.height;
  const ctx = lightboxCanvas.getContext('2d')!;
  ctx.drawImage(cleanedCanvas, 0, 0);
  lightbox.classList.remove('hidden');
  document.body.style.overflow = 'hidden';
});

function closeLightbox() {
  lightbox.classList.add('hidden');
  document.body.style.overflow = '';
}

lightboxClose.addEventListener('click', closeLightbox);
lightbox.addEventListener('click', (e) => {
  if (e.target === lightbox) closeLightbox();
});
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && !lightbox.classList.contains('hidden')) closeLightbox();
});
</script>
