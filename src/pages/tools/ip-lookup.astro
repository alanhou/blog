---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="IP Lookup Tool / IP地址查询工具">
  <div class="tool-page">
    <h1>IP Lookup Tool</h1>
    <p class="subtitle">Look up IP address information including location, ISP, and network details / 查询IP地址信息，包括位置、ISP和网络详情</p>

    <div class="tool-container">
      <div class="input-section">
        <label for="ip-input">IP Address:</label>
        <input type="text" id="ip-input" placeholder="Loading your IP...">
      </div>

      <div class="button-group">
        <button id="lookup-btn" class="primary-btn">Lookup IP</button>
        <button id="my-ip-btn" class="secondary-btn">My IP</button>
      </div>

      <div id="output-section" class="output-section hidden">
        <div class="result-card">
          <div class="result-row">
            <span class="label">IP Address:</span>
            <div class="value-with-copy">
              <span class="value" id="ip-value">-</span>
              <button id="copy-ip-btn" class="copy-btn" title="Copy IP address">📋</button>
            </div>
          </div>
          <div class="result-row">
            <span class="label">Location:</span>
            <span class="value" id="location-value">-</span>
          </div>
          <div class="result-row">
            <span class="label">Coordinates:</span>
            <span class="value" id="coordinates-value">-</span>
          </div>
          <div class="result-row">
            <span class="label">Organization:</span>
            <span class="value" id="org-value">-</span>
          </div>
          <div class="result-row">
            <span class="label">Hostname:</span>
            <span class="value" id="hostname-value">-</span>
          </div>
          <div class="result-row">
            <span class="label">Postal Code:</span>
            <span class="value" id="postal-value">-</span>
          </div>
          <div class="result-row">
            <span class="label">Timezone:</span>
            <span class="value" id="timezone-value">-</span>
          </div>
        </div>
      </div>

      <div id="error-section" class="error-section hidden">
        <p id="error-message"></p>
      </div>
    </div>

    <div class="info-section">
      <h2>Quick Examples</h2>
      <div class="examples">
        <button class="example-btn" data-ip="8.8.8.8">Google DNS (8.8.8.8)</button>
        <button class="example-btn" data-ip="1.1.1.1">Cloudflare DNS (1.1.1.1)</button>
        <button class="example-btn" data-ip="9.9.9.9">Quad9 DNS (9.9.9.9)</button>
      </div>

      <h2>About</h2>
      <p>This tool uses the ipinfo.io API to provide geolocation and network information for IP addresses. Free tier includes 50,000 requests per month.</p>

      <h3>Use Cases:</h3>
      <ul>
        <li>Security research and threat analysis</li>
        <li>Network troubleshooting and diagnostics</li>
        <li>Geolocation verification</li>
        <li>ISP and hosting provider identification</li>
      </ul>
    </div>
  </div>
</Layout>

<style>
.tool-page {
  max-width: 700px;
  margin: 0 auto;
  padding: 2rem 0;
}

.subtitle {
  color: var(--text-secondary);
  margin-bottom: 2rem;
}

.tool-container {
  background: var(--bg-secondary);
  padding: 2rem;
  border-radius: 12px;
  margin-bottom: 2rem;
}

.input-section {
  margin-bottom: 1.5rem;
}

.input-section label {
  display: block;
  margin-bottom: 0.5rem;
  color: var(--text-secondary);
  font-size: 0.9rem;
}

.input-section input {
  width: 100%;
  padding: 1rem;
  font-size: 1rem;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: var(--bg);
  color: var(--text);
  font-family: 'Monaco', 'Courier New', monospace;
}

.primary-btn {
  flex: 1;
  padding: 1rem;
  font-size: 1rem;
  font-weight: 600;
  background: var(--primary);
  color: white;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  transition: opacity 0.2s;
}

.primary-btn:hover {
  opacity: 0.9;
}

.primary-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.button-group {
  display: flex;
  gap: 0.5rem;
}

.secondary-btn {
  padding: 1rem;
  font-size: 1rem;
  font-weight: 600;
  background: var(--bg);
  color: var(--text);
  border: 1px solid var(--border);
  border-radius: 8px;
  cursor: pointer;
  transition: background 0.2s;
}

.secondary-btn:hover {
  background: var(--border);
}

.secondary-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.output-section {
  margin-top: 2rem;
}

.result-card {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 1.5rem;
}

.result-row {
  display: flex;
  justify-content: space-between;
  padding: 0.75rem 0;
  border-bottom: 1px solid var(--border);
}

.result-row:last-child {
  border-bottom: none;
}

.result-row .label {
  color: var(--text-secondary);
  font-size: 0.9rem;
  font-weight: 500;
}

.result-row .value {
  color: var(--text);
  font-family: 'Monaco', 'Courier New', monospace;
  font-size: 0.9rem;
  text-align: right;
}

.value-with-copy {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.copy-btn {
  background: var(--bg-secondary);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 0.25rem 0.5rem;
  cursor: pointer;
  font-size: 0.9rem;
  transition: background 0.2s;
}

.copy-btn:hover {
  background: var(--border);
}

.copy-btn:active {
  transform: scale(0.95);
}

.copy-btn.copied {
  background: #4caf50;
  border-color: #4caf50;
}

.error-section {
  margin-top: 2rem;
  padding: 1rem;
  background: #fee;
  border: 1px solid #fcc;
  border-radius: 8px;
  color: #c33;
}

.hidden {
  display: none !important;
}

.info-section {
  background: var(--bg-secondary);
  padding: 2rem;
  border-radius: 12px;
}

.info-section h2 {
  margin-top: 1.5rem;
  margin-bottom: 1rem;
  font-size: 1.2rem;
}

.info-section h2:first-child {
  margin-top: 0;
}

.info-section h3 {
  margin-top: 1rem;
  margin-bottom: 0.5rem;
  font-size: 1rem;
}

.info-section p {
  color: var(--text-secondary);
  line-height: 1.6;
}

.info-section ul {
  color: var(--text-secondary);
  line-height: 1.8;
  padding-left: 1.5rem;
}

.examples {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  margin-bottom: 1rem;
}

.example-btn {
  padding: 0.5rem 1rem;
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 6px;
  cursor: pointer;
  color: var(--text);
  font-size: 0.9rem;
  transition: background 0.2s;
}

.example-btn:hover {
  background: var(--border);
}

  @media (max-width: 480px) {
  .result-row {
    flex-direction: column;
    gap: 0.25rem;
  }

  .result-row .value {
    text-align: left;
  }

  .examples {
    flex-direction: column;
  }

  .example-btn {
    width: 100%;
  }

  .button-group {
    flex-direction: column;
  }
}
</style>

<script is:inline>
document.addEventListener('DOMContentLoaded', function() {
  var ipInput = document.getElementById('ip-input');
  var lookupBtn = document.getElementById('lookup-btn');
  var myIpBtn = document.getElementById('my-ip-btn');
  var outputSection = document.getElementById('output-section');
  var errorSection = document.getElementById('error-section');
  var errorMessage = document.getElementById('error-message');
  var currentIP = null;

  // Fetch current user's IP on load
  async function fetchMyIP() {
    try {
      var response = await fetch('https://ipinfo.io/json');
      if (!response.ok) throw new Error('Failed to fetch IP');
      var data = await response.json();
      currentIP = data.ip;
      ipInput.placeholder = currentIP;
      ipInput.value = currentIP;
      // Auto-lookup on page load
      updateResult(data);
    } catch (error) {
      console.error('Failed to fetch current IP:', error);
      ipInput.placeholder = '8.8.8.8';
    }
  }

  fetchMyIP();

  function showError(message) {
    errorMessage.textContent = message;
    errorSection.classList.remove('hidden');
    outputSection.classList.add('hidden');
  }

  function hideError() {
    errorSection.classList.add('hidden');
  }

  function updateResult(data) {
    document.getElementById('ip-value').textContent = data.ip || '-';

    var location = [];
    if (data.city) location.push(data.city);
    if (data.region) location.push(data.region);
    if (data.country) location.push(data.country);
    document.getElementById('location-value').textContent = location.length > 0 ? location.join(', ') : '-';

    document.getElementById('coordinates-value').textContent = data.loc || '-';
    document.getElementById('org-value').textContent = data.org || '-';
    document.getElementById('hostname-value').textContent = data.hostname || '-';
    document.getElementById('postal-value').textContent = data.postal || '-';
    document.getElementById('timezone-value').textContent = data.timezone || '-';

    outputSection.classList.remove('hidden');
    hideError();
  }

  // Copy IP to clipboard
  var copyIpBtn = document.getElementById('copy-ip-btn');
  copyIpBtn.addEventListener('click', function() {
    var ipValue = document.getElementById('ip-value').textContent;
    if (ipValue && ipValue !== '-') {
      navigator.clipboard.writeText(ipValue).then(function() {
        copyIpBtn.textContent = '✓';
        copyIpBtn.classList.add('copied');
        setTimeout(function() {
          copyIpBtn.textContent = '📋';
          copyIpBtn.classList.remove('copied');
        }, 2000);
      }).catch(function(err) {
        console.error('Failed to copy:', err);
      });
    }
  });

  async function lookupIP(ip) {
    if (!ip || !ip.trim()) {
      showError('Please enter an IP address');
      return;
    }

    lookupBtn.disabled = true;
    lookupBtn.textContent = 'Looking up...';
    hideError();

    try {
      var response = await fetch('https://ipinfo.io/' + ip.trim() + '/json');

      if (!response.ok) {
        throw new Error('Failed to lookup IP: ' + response.statusText);
      }

      var data = await response.json();

      if (data.error) {
        throw new Error(data.error.message || 'Invalid IP address');
      }

      updateResult(data);
    } catch (error) {
      console.error('Lookup error:', error);
      showError(error.message || 'Failed to lookup IP address');
    } finally {
      lookupBtn.disabled = false;
      lookupBtn.textContent = 'Lookup IP';
    }
  }

  lookupBtn.addEventListener('click', function() {
    lookupIP(ipInput.value);
  });

  myIpBtn.addEventListener('click', function() {
    if (currentIP) {
      ipInput.value = currentIP;
      lookupIP(currentIP);
    } else {
      fetchMyIP();
    }
  });

  ipInput.addEventListener('keypress', function(e) {
    if (e.key === 'Enter') {
      lookupIP(ipInput.value);
    }
  });

  // Example buttons
  var exampleBtns = document.querySelectorAll('.example-btn');
  exampleBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var ip = btn.getAttribute('data-ip');
      ipInput.value = ip;
      lookupIP(ip);
    });
  });
});
</script>
</Layout>
