---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
const tools = await getCollection('tools');

const builtInTools = [
  {
    title: { en: 'Password Generator', zh: '密码生成器' },
    description: { en: 'Generate secure random passwords with customizable options', zh: '生成安全随机密码，支持自定义选项' },
    url: '/tools/password-generator',
    icon: '🔐'
  },
  {
    title: { en: 'Base64 Image Encoder/Decoder', zh: 'Base64图片编解码' },
    description: { en: 'Convert images to/from Base64 format', zh: '图片与Base64格式互转' },
    url: '/tools/base64-image',
    icon: '🖼️'
  },
  {
    title: { en: 'QR Code Generator', zh: '二维码生成器' },
    description: { en: 'Generate QR codes from URLs or text with custom colors', zh: '从URL或文本生成二维码，支持自定义颜色' },
    url: '/tools/qrcode-generator',
    icon: '📱'
  },
  {
    title: { en: 'JSON Parser & Viewer', zh: 'JSON解析查看器' },
    description: { en: 'Parse, format, and view JSON data with syntax highlighting', zh: '解析、格式化和查看JSON数据，支持语法高亮' },
    url: '/tools/json-viewer',
    icon: '🔧'
  },
  {
    title: { en: 'Unix Time Converter', zh: 'Unix时间戳转换' },
    description: { en: 'Convert between Unix timestamps and dates, supports seconds and milliseconds', zh: 'Unix时间戳与日期互转，支持秒和毫秒' },
    url: '/tools/unix-time',
    icon: '⏱️'
  },
  {
    title: { en: 'Gemini Watermark Remover', zh: 'Gemini水印移除' },
    description: { en: 'Remove Gemini\'s visible watermark from AI-generated images', zh: '移除Gemini AI生成图片的可见水印' },
    url: '/tools/gemini-watermark',
    icon: '✨'
  },
  {
    title: { en: '即梦AI Watermark Remover', zh: '即梦AI水印移除' },
    description: { en: 'Remove 即梦AI\'s visible watermark from AI-generated images', zh: '移除即梦AI生成图片的可见水印' },
    url: '/tools/jimeng-watermark',
    icon: '🎨'
  },
  {
    title: { en: 'IP Lookup', zh: 'IP地址查询' },
    description: { en: 'Look up geolocation and details for any IP address', zh: '查询任意IP地址的地理位置和详细信息' },
    url: '/tools/ip-lookup',
    icon: '🌍'
  },
  {
    title: { en: 'Regex Tester', zh: '正则表达式测试器' },
    description: { en: 'Test regular expressions with common patterns and real-time highlighting', zh: '测试正则表达式，内置常用模式和实时高亮' },
    url: '/tools/regex-tester',
    icon: '🔍'
  }
];
---
<Layout title="Tools / 工具">
<h1>Tools / 工具</h1>
<p>Useful development and utility tools. / 实用开发工具集</p>

<h2 class="section-title">Built-in Tools / 内置工具</h2>
<div class="tools-grid">
  {builtInTools.map(tool => (
    <a href={tool.url} class="tool-card">
      <span class="tool-icon">{tool.icon}</span>
      <h3>{tool.title.en}</h3>
      <p class="zh-title">{tool.title.zh}</p>
      <p class="description">{tool.description.en}</p>
    </a>
  ))}
</div>

{tools.length > 0 && (
  <>
    <h2 class="section-title">External Tools / 外部工具</h2>
    <div class="tools-grid">
      {tools.map(tool => (
        <a href={tool.data.url} target="_blank" rel="noopener" class="tool-card external">
          <h3>{tool.data.title?.en || tool.data.title?.zh}</h3>
          <p class="description">{tool.data.description?.en || tool.data.description?.zh}</p>
          <span class="pricing">{tool.data.pricing}</span>
        </a>
      ))}
    </div>
  </>
)}
</Layout>

<style>
h1 {
  margin-bottom: 0.5rem;
}

h1 + p {
  color: var(--text-secondary);
  margin-bottom: 2rem;
}

.section-title {
  font-size: 1.25rem;
  margin: 2rem 0 1rem;
  color: var(--text);
}

.tools-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 1.5rem;
}

.tool-card {
  padding: 1.5rem;
  border: 1px solid var(--border);
  border-radius: 12px;
  text-decoration: none;
  color: var(--text);
  transition: border-color 0.2s, transform 0.2s;
  display: block;
}

.tool-card:hover {
  border-color: var(--primary);
  transform: translateY(-2px);
}

.tool-icon {
  font-size: 2rem;
  display: block;
  margin-bottom: 0.75rem;
}

.tool-card h3 {
  color: var(--primary);
  margin-bottom: 0.25rem;
  font-size: 1.1rem;
}

.tool-card .zh-title {
  color: var(--text-secondary);
  font-size: 0.9rem;
  margin-bottom: 0.75rem;
}

.tool-card .description {
  color: var(--text-secondary);
  font-size: 0.9rem;
  line-height: 1.5;
}

.tool-card.external h3::after {
  content: ' ↗';
  font-size: 0.8em;
  opacity: 0.5;
}

.pricing {
  display: inline-block;
  padding: 0.25rem 0.5rem;
  background: var(--bg-secondary);
  border-radius: 4px;
  font-size: 0.8rem;
  margin-top: 0.75rem;
}

@media (max-width: 640px) {
  .tools-grid {
    grid-template-columns: 1fr;
  }
}
</style>
