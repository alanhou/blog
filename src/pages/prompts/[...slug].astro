---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BilingualContent from '../../components/BilingualContent.astro';

export async function getStaticPaths() {
  const prompts = await getCollection('prompts');
  return prompts.map(prompt => ({
    params: { slug: prompt.slug },
    props: { prompt },
  }));
}

const { prompt } = Astro.props;
const { Content } = await prompt.render();
const titleEn = prompt.data.title.en || '';
const titleZh = prompt.data.title.zh || '';
const title = titleEn && titleZh ? `${titleEn} / ${titleZh}` : titleEn || titleZh || 'Prompt';
const description = prompt.data.description?.en || prompt.data.description?.zh || '';
const tags = prompt.data.tags || [];

// Extract raw markdown content for each language
const rawContent = prompt.body;
const enMatch = rawContent.match(/:::en\s+([\s\S]*?)(?=\n:::|\s*$)/);
const zhMatch = rawContent.match(/:::zh\s+([\s\S]*?)(?=\n:::|\s*$)/);
// Remove any trailing ::: markers and credit sections
const enContent = enMatch ? enMatch[1].trim().replace(/:::+\s*$/, '').replace(/\n---\s*\n\*\*Credit:\*\*[\s\S]*$/, '').trim() : '';
const zhContent = zhMatch ? zhMatch[1].trim().replace(/:::+\s*$/, '').replace(/\n---\s*\n\*\*Credit:\*\*[\s\S]*$/, '').trim() : '';
---

<Layout title={title} description={description || undefined}>
  <article class="prompt-page">
    <header class="prompt-header">
      <h1 class="prompt-title">{prompt.data.title.en}</h1>
      {prompt.data.title.zh && <h2 class="prompt-title-zh">{prompt.data.title.zh}</h2>}
      <div class="prompt-meta">
        <span class="category-tag">{prompt.data.category}</span>
        {tags.length > 0 && (
          <div class="prompt-tags">
            {tags.map((tag: string) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </header>

    <div class="copy-section">
      {enContent && (
        <button class="copy-btn" data-lang="en" data-content={enContent} title="Copy English prompt">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
          </svg>
          Copy English
        </button>
      )}
      {zhContent && (
        <button class="copy-btn" data-lang="zh" data-content={zhContent} title="Copy Chinese prompt">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
          </svg>
          复制中文
        </button>
      )}
    </div>

    <div class="prompt-content" id="prompt-content">
      <BilingualContent>
        <Content />
      </BilingualContent>
    </div>

    <nav class="prompt-nav">
      <a href="/prompts" class="back-link">← Back to Prompts</a>
    </nav>
  </article>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const copyButtons = document.querySelectorAll('.copy-btn[data-content]');

    copyButtons.forEach(btn => {
      btn.addEventListener('click', async () => {
        try {
          const content = btn.getAttribute('data-content');
          if (!content) return;

          await navigator.clipboard.writeText(content);

          // Visual feedback
          const originalHTML = btn.innerHTML;
          const lang = btn.getAttribute('data-lang');
          btn.innerHTML = lang === 'en' ? '✓ Copied!' : '✓ 已复制!';
          btn.classList.add('copied');

          setTimeout(() => {
            btn.innerHTML = originalHTML;
            btn.classList.remove('copied');
          }, 2000);
        } catch (err) {
          console.error('Failed to copy:', err);
          const lang = btn.getAttribute('data-lang');
          btn.innerHTML = lang === 'en' ? '✗ Failed' : '✗ 失败';
          setTimeout(() => {
            btn.innerHTML = btn.innerHTML;
          }, 2000);
        }
      });
    });
  });
</script>

<style>
  .prompt-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 0;
  }

  .prompt-header {
    margin-bottom: 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--border);
  }

  .prompt-title {
    font-size: 2.25rem;
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 0.5rem;
    color: var(--text);
  }

  .prompt-title-zh {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .prompt-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem;
  }

  .category-tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: var(--primary);
    color: white;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .prompt-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    background: var(--bg-secondary);
    color: var(--text-secondary);
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.8rem;
    transition: all 0.2s;
  }

  .tag:hover {
    background: var(--primary);
    color: white;
  }

  .copy-section {
    margin-bottom: 1.5rem;
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
  }

  .copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: var(--primary);
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 0.95rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }

  .copy-btn:hover {
    background: var(--primary-dark);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(83, 165, 81, 0.3);
  }

  .copy-btn.copied {
    background: #10b981;
  }

  .copy-btn svg {
    flex-shrink: 0;
  }

  .prompt-content {
    font-size: 1.05rem;
    line-height: 1.75;
  }

  /* Prose styling for content */
  .prompt-content :global(h1),
  .prompt-content :global(h2) {
    font-size: 1.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--primary);
  }

  .prompt-content :global(h3) {
    font-size: 1.35rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--text);
  }

  .prompt-content :global(h4) {
    font-size: 1.15rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .prompt-content :global(p) {
    margin-bottom: 1.25rem;
  }

  .prompt-content :global(ul),
  .prompt-content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .prompt-content :global(li) {
    margin-bottom: 0.5rem;
  }

  .prompt-content :global(blockquote) {
    border-left: 4px solid var(--primary);
    padding: 1rem 1.5rem;
    margin: 1.5rem 0;
    background: var(--bg-secondary);
    border-radius: 0 8px 8px 0;
  }

  .prompt-content :global(pre) {
    margin: 1.5rem 0;
    border-radius: 8px;
  }

  .prompt-content :global(code) {
    background: var(--bg-secondary);
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    font-size: 0.9em;
  }

  .prompt-content :global(pre code) {
    background: transparent;
    padding: 0;
  }

  .prompt-content :global(strong) {
    font-weight: 600;
    color: var(--text);
  }

  .prompt-nav {
    max-width: 900px;
    margin: 2rem auto 0;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--primary);
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: var(--primary-dark);
  }

  @media (max-width: 768px) {
    .prompt-page {
      padding: 1rem 0;
    }

    .prompt-title {
      font-size: 1.75rem;
    }

    .prompt-title-zh {
      font-size: 1.25rem;
    }

    .prompt-content {
      font-size: 1rem;
    }
  }
</style>
