---
interface Props {
  ip: string;
  inline?: boolean;
}

const { ip, inline = false } = Astro.props;
---

<span class="ip-lookup" data-ip={ip} data-inline={inline}>
  <span class="ip-address">{ip}</span>
  <span class="ip-info">...</span>
</span>

<style>
  .ip-lookup {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Monaco', 'Courier New', monospace;
  }

  .ip-address {
    color: var(--text-primary);
    font-weight: 500;
  }

  .ip-info {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }

  .ip-lookup[data-inline="false"] {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem;
    background: var(--bg-secondary, #f5f5f5);
    border-radius: 0.5rem;
    margin: 1rem 0;
  }

  .ip-lookup[data-inline="false"] .ip-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .ip-lookup.loading .ip-info {
    opacity: 0.5;
  }

  .ip-lookup.error .ip-info {
    color: var(--error-color, #dc2626);
  }
</style>

<script>
  interface IPInfo {
    ip: string;
    city?: string;
    region?: string;
    country?: string;
    loc?: string;
    org?: string;
    hostname?: string;
    postal?: string;
    timezone?: string;
  }

  async function lookupIP(ip: string): Promise<IPInfo> {
    const response = await fetch(`https://ipinfo.io/${ip}/json`);
    if (!response.ok) {
      throw new Error(`Failed to lookup IP: ${response.statusText}`);
    }
    return response.json();
  }

  function formatIPInfo(data: IPInfo, inline: boolean): string {
    if (inline) {
      const parts = [];
      if (data.city) parts.push(data.city);
      if (data.country) parts.push(data.country);
      if (data.org) parts.push(data.org);
      return parts.length > 0 ? `(${parts.join(', ')})` : '';
    }

    const lines = [];
    if (data.city || data.region || data.country) {
      const location = [data.city, data.region, data.country].filter(Boolean).join(', ');
      lines.push(`📍 ${location}`);
    }
    if (data.org) lines.push(`🏢 ${data.org}`);
    if (data.hostname) lines.push(`🌐 ${data.hostname}`);
    if (data.timezone) lines.push(`🕐 ${data.timezone}`);

    return lines.join('\n');
  }

  function initIPLookup() {
    const elements = document.querySelectorAll('.ip-lookup');

    elements.forEach(async (el) => {
      const htmlEl = el as HTMLElement;
      const ip = htmlEl.dataset.ip;
      const inline = htmlEl.dataset.inline === 'true';

      if (!ip) return;

      const infoEl = el.querySelector('.ip-info');
      if (!infoEl) return;

      htmlEl.classList.add('loading');

      try {
        const data = await lookupIP(ip);
        const formatted = formatIPInfo(data, inline);

        if (inline) {
          infoEl.textContent = formatted;
        } else {
          infoEl.innerHTML = formatted.split('\n').map(line =>
            `<div>${line}</div>`
          ).join('');
        }

        htmlEl.classList.remove('loading');
      } catch (error) {
        console.error('IP lookup failed:', error);
        infoEl.textContent = inline ? '(lookup failed)' : '❌ Failed to lookup IP';
        htmlEl.classList.remove('loading');
        htmlEl.classList.add('error');
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initIPLookup);
  document.addEventListener('astro:page-load', initIPLookup);
</script>
